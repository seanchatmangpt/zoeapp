{
  "name": "expo-supabase-ai-template",
  "version": "1.0.0",
  "description": "A modern React Native template with Expo Router, Supabase authentication, and OpenAI integration",
  "author": "Your Name",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
